<div class="overlay brutal-overlay"></div>
<dialog id="dialog-posts" class="brutal-dialog brutal-dialog-large">
    <header class="brutal-dialog-header">
        <nav class="brutal-dialog-nav">
            <h6 class="brutal-dialog-title">Moje posty</h6>
            <div class="brutal-dialog-actions">
                <a class="brutal-icon-btn" href="/tags/posts/" target="_blank">
                    <i>{% icon "lucide:external-link" %}</i>
                    <span class="brutal-tooltip brutal-tooltip-bottom">Otwórz w nowej zakładce</span>
                </a>
                <button class="brutal-icon-btn" data-ui="#dialog-posts">
                    <i>{% icon "lucide:x" %}</i>
                </button>
            </div>
        </nav>
    </header>

    <div class="brutal-dialog-content">
        <div class="brutal-dialog-grid">
            {% for post in collections.posts | reverse %}
            <article class="bento-card bento-card-compact">
                <div class="bento-tags-wrapper">
                    {% set hasTags = false %}
                    {% for tag in post.data.tags %}
                        {% if "posts" not in tag and "post" not in tag %}
                        <a class="tag" href="/tags/{{ tag | slugify }}/">#{{ tag }}</a>
                        {% set hasTags = true %}
                        {% endif %}
                    {% endfor %}
                    {% if not hasTags %}
                        <a href="/tags/wpis/" class="tag">#Wpis</a>
                    {% endif %}
                </div>
                <p class="bento-card-date">{{ post.date | readableDate }}</p>
                <h3 class="bento-card-title">{{ post.data.title }}</h3>
                <p class="bento-card-desc">{{ post.data.description | default('Kliknij, aby przeczytać.') }}</p>
                <a href="{{ post.url }}" class="read-more">Czytaj dalej &rarr;</a>
            </article>
            {% endfor %}
        </div>
    </div>
</dialog>
