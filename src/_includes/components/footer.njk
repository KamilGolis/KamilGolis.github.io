<div class="large-space"></div>
<footer class="brutal-footer">

  <div class="brutal-footer-brand">
    <a class="brutal-footer-name" href="{{ site.url }}">{{ site.title }}</a>
    <p class="brutal-footer-desc">{{ site.description }}</p>
  </div>

  <div class="brutal-footer-social">
    {% for item in site.socialItems %}
    <a class="brutal-footer-icon" href="{{ item.url }}" aria-label="{{ item.title }}" {% if item.rel %}rel="{{ item.rel }}"{% endif %}>
      {% icon item.icon %}
    </a>
    {% endfor %}
  </div>

</footer>