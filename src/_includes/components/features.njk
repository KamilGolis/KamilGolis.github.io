<div class="hero grid">

    <div class="s12 m12 l6 center-align" style="padding: 2rem;">
        <img src="{{ site.hero.image.src }}" width="100%" height="100%" fetchpriority="high"
            alt="{{ site.hero.image.alt }}" title="{{ site.hero.image.alt }}">
    </div>

    <div class="s12 m12 l6">

        <p>{{ site.hero.name }}</p>
        <h1>{{ site.hero.title }}</h1>
        <p>{{ site.hero.description }}</p>

        <div class="large-space"></div>

        <nav class="row" style="flex-wrap: wrap; gap: 1rem;">
            {% for btn in site.hero.buttons %}
            <a class="button {{ btn.extraClass }}" href="{{ btn.url }}">
                {% if btn.icon %}
                <i>{% icon btn.icon %}</i>
                {% endif %}
                {{ btn.text }}
                {% if btn.sr %}
                <span class="sr-only">{{ btn.sr }}</span>
                {% endif %}
            </a>
            {% endfor %}
        </nav>

    </div>

</div>

<div class="features center-align">

    <ul class="list" style="margin: 2rem 0;">
        {% for item in site.features.items %}
        <li class="
          {% if loop.first %}top-round{% endif %}
          {% if loop.last %}bottom-round{% endif %}
        ">
            <i>{% icon item.icon %}</i>
            <div style="flex: 1; text-align: left;">
                <h6 class="small">{{ item.title }}</h6>
                <div class="small-text">{{ item.helper }}</div>
            </div>
        </li>
        {% endfor %}
    </ul>

    {% if site.features.button.enabled %}
    <div class="large-space"></div>

    <a class="button mesh extra" href="{{ site.features.button.url }}" style="width: 100%; max-width: 400px;">
        <i>{% icon site.features.button.icon %}</i>
        <span>{{ site.features.button.text }}</span>
    </a>
    {% endif %}

</div>
