<div class="overlay brutal-overlay"></div>
<dialog id="dialog-tags" class="brutal-dialog">
    <header class="brutal-dialog-header">
        <nav class="brutal-dialog-nav">
            
            <div class="brutal-dialog-title-wrapper">
                <h6 class="brutal-dialog-title brutal-truncate">Wszystkie tagi</h6>
            </div>
            
            <div class="brutal-dialog-actions">
                <a class="brutal-icon-btn" href="/tags/" target="_blank">
                    <i>{% icon "lucide:external-link" %}</i>
                    <span class="brutal-tooltip brutal-tooltip-bottom">Otwórz w nowej zakładce</span>
                </a>
                <button class="brutal-icon-btn" data-ui="#dialog-tags">
                    <i>{% icon "lucide:x" %}</i>
                </button>
            </div>
            
        </nav>
    </header>
    
    <div class="brutal-dialog-content">
        <ul class="brutal-tag-list">
            {% for tag in collections.tagsList %}
            <li class="brutal-tag-item">
                <a class="brutal-tag-link{% if page.url == '/tags/' ~ (tag | slug) ~ '/' %} active{% endif %}" data-ui="#dialog-tags" href="/tags/{{ tag | slug }}/">
                    <i>{% icon "lucide:hash" %}</i>
                    {{ tag }}
                </a>       
            </li> 
            {% endfor %}
        </ul>
    </div>
</dialog>
