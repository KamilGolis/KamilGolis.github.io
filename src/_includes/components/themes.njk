<div class="overlay transparent"></div>
<dialog id="dialog-themes" class="brutal-dialog">
    <header class="brutal-dialog-header fixed">
        <nav class="brutal-dialog-nav">
            <div class="brutal-dialog-title-wrapper">
                <h5 class="brutal-dialog-title">Kolorystyka</h5>
            </div>
            <div class="brutal-dialog-actions">
                <button class="brutal-icon-btn button circle border large" onclick="mode()">
                    <i class="dark">{% icon "lucide:moon" %}</i>
                    <i class="light">{% icon "lucide:sun" %}</i>
                    <div class="tooltip bottom">Toggle theme</div>
                </button>
                <button class="brutal-icon-btn button circle transparent" data-ui="#dialog-themes">
                    <i>{% icon "lucide:x" %}</i>
                </button>
            </div>
        </nav>
    </header>
    <div class="brutal-dialog-content" style="padding-top: 6rem;">
        <nav class="row" style="flex-wrap: wrap; gap: 0.5rem; justify-content: center;">
            <button class="button circle" style="background-color: #f44336; width: 40px; height: 40px;" onclick="theme('#f44336')"></button>
            <button class="button circle" style="background-color: #e91e63; width: 40px; height: 40px;" onclick="theme('#e91e63')"></button>
            <button class="button circle" style="background-color: #9c27b0; width: 40px; height: 40px;" onclick="theme('#9c27b0')"></button>
            <button class="button circle" style="background-color: #673ab7; width: 40px; height: 40px;" onclick="theme('#673ab7')"></button>
            <button class="button circle" style="background-color: #3f51b5; width: 40px; height: 40px;" onclick="theme('#3f51b5')"></button>
            <button class="button circle" style="background-color: #2196f3; width: 40px; height: 40px;" onclick="theme('#2196f3')"></button>
            <button class="button circle" style="background-color: #03a9f4; width: 40px; height: 40px;" onclick="theme('#03a9f4')"></button>
            <button class="button circle" style="background-color: #00bcd4; width: 40px; height: 40px;" onclick="theme('#00bcd4')"></button>
            <button class="button circle" style="background-color: #009688; width: 40px; height: 40px;" onclick="theme('#009688')"></button>
            <button class="button circle" style="background-color: #4caf50; width: 40px; height: 40px;" onclick="theme('#4caf50')"></button>
            <button class="button circle" style="background-color: #8bc34a; width: 40px; height: 40px;" onclick="theme('#8bc34a')"></button>
            <button class="button circle" style="background-color: #cddc39; width: 40px; height: 40px;" onclick="theme('#cddc39')"></button>
            <button class="button circle" style="background-color: #ffeb3b; width: 40px; height: 40px;" onclick="theme('#ffeb3b')"></button>
            <button class="button circle" style="background-color: #ffc107; width: 40px; height: 40px;" onclick="theme('#ffc107')"></button>
            <button class="button circle" style="background-color: #ff9800; width: 40px; height: 40px;" onclick="theme('#ff9800')"></button>
            <button class="button circle" style="background-color: #ff5722; width: 40px; height: 40px;" onclick="theme('#ff5722')"></button>
            <button class="button circle" style="background-color: #795548; width: 40px; height: 40px;" onclick="theme('#795548')"></button>
            <button class="button circle" style="background-color: #9e9e9e; width: 40px; height: 40px;" onclick="theme('#9e9e9e')"></button>
            <button class="button circle" style="background-color: #607d8b; width: 40px; height: 40px;" onclick="theme('#607d8b')"></button>
            <button class="button circle" style="background-color: #000000; width: 40px; height: 40px;" onclick="theme('#000000')"></button>
            <button class="button circle" style="background-color: #ffffff; border-color: #000; width: 40px; height: 40px;" onclick="theme('#ffffff')"></button>
        </nav>
        <nav style="margin-top: 2rem;">
            <button class="button" style="background-color: {{ site.theme }}; width: 100%; border-radius: 8px;" onclick="theme('{{ site.theme }}')">
                <i>{% icon "lucide:rotate-ccw" %}</i>
                <span>Use default theme</span>
            </button>
        </nav>
    </div>
</dialog>
