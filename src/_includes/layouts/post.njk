---
layout: layouts/default.njk
---
<div class="large-space"></div>

<header class="brutal-article-header">

    {% if site.cover %}
    <div class="grid">
        <div class="s12 m12 l6 brutal-article-col">
    {% else %}
        <div>
    {% endif %}

            <div>
                <div class="brutal-article-meta" data-pagefind-ignore style="margin-bottom: 1rem;">
                    📅 {{ date | readableDate }}
                    {% if lastUpdated %}
                        <span class="brutal-meta-divider">//</span>
                        Aktualizacja: {{ lastUpdated | readableDate }}
                    {% endif %}
                </div>
                
                <h1 data-pagefind-meta="title" class="brutal-article-title">{{ title }}</h1>
                <p class="brutal-article-desc">{{ description }}</p>
            </div>
            
            <div class="brutal-article-actions-bar">
                
                <nav class="bento-tags-wrapper brutal-tags-nav" data-pagefind-ignore>
                    {% for tag in tags %}
                        {% if "posts" not in tag %}
                            <a class="tag" href="/tags/{{ tag }}/">#{{ tag }}</a>
                        {% endif %}
                    {% endfor %}
                </nav>
                
                <nav class="brutal-github-nav post-action">
                    <a href="https://raw.githubusercontent.com/{{ site.ghRepo }}/main/src/posts/{{ page.fileSlug }}.md"
                        class="brutal-icon-btn" aria-label="Pokaż źródło strony">
                        <i>{% icon "lucide:file-braces" %}</i>
                        <span class="brutal-tooltip brutal-tooltip-bottom">Pokaż źródło strony</span>
                    </a>
                    <a href="https://github.com/{{ site.ghRepo }}/commits/main/src/posts/{{ page.fileSlug }}.md"
                        class="brutal-icon-btn" aria-label="Historia strony">
                        <i>{% icon "lucide:file-clock" %}</i>
                        <span class="brutal-tooltip brutal-tooltip-bottom">Pokaż historię strony</span>
                    </a>
                    <a href="https://github.com/{{ site.ghRepo }}/edit/main/src/posts/{{ page.fileSlug }}.md"
                        class="brutal-icon-btn" aria-label="Edytuj stronę">
                        <i>{% icon "lucide:file-pen" %}</i>
                        <span class="brutal-tooltip brutal-tooltip-bottom">Edytuj stronę</span>
                    </a>
                </nav>
            </div>

    {% if site.cover %}
        </div>
        
        <div class="s12 m12 l6 post-cover">
            {% if cover %}
            <img class="brutal-cover-img" src="{{ cover.img }}" alt="{{ cover.alt }}" title="{{ cover.alt }}">
            {% endif %}
        </div>
    </div>
    {% else %}
        </div>
    {% endif %}

</header>

<div class="brutal-author-block">
    {% include "components/profile.njk" %}
    <div>
        <div class="brutal-author-label">Autor</div>
        <div class="brutal-author-name">{{ site.author }}</div>
    </div>
</div>

<div class="brutal-post-buttons-wrapper">
    {% include "components/post-buttons.njk" %}
</div>

<article class="brutal-content">
    {{ content | safe }}
</article>

<dialog id="dialog-toc" class="brutal-dialog">
    <div class="brutal-dialog-header">
        <h3>Spis zawartości</h3>
        <button class="brutal-icon-btn" data-ui="#dialog-toc" aria-label="Zamknij">
            <i>{% icon "lucide:x" %}</i>
        </button>
    </div>
    <div class="brutal-content">
        {{ content | toc | safe }}
    </div>
</dialog>
