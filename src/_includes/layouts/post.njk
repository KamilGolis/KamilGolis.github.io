---
layout: layouts/default.njk
---
<div class="large-space"></div>

<header class="brutal-article-header">

    {% if site.cover %}
    <div class="grid">
        <div class="s12 m12 l6 brutal-article-col">
    {% else %}
        <div>
    {% endif %}

            <div>
                <div class="brutal-article-meta" data-pagefind-ignore>
                    📅 {{ date | readableDate }}
                    {% if lastUpdated %}
                        <span class="brutal-meta-divider">//</span>
                        {{ site.i18n.updated }}: {{ lastUpdated | readableDate }}
                    {% endif %}
                </div>
                
                <h1 data-pagefind-meta="title" class="brutal-article-title">{{ title }}</h1>
                <p class="brutal-article-desc">{{ description }}</p>
            </div>
            
            <div class="brutal-article-actions-bar">
                
                <nav class="bento-tags-wrapper brutal-tags-nav" data-pagefind-ignore>
                    {% for tag in tags %}
                        {% if "posts" not in tag %}
                            <a class="tag" href="/tags/{{ tag }}/">#{{ tag }}</a>
                        {% endif %}
                    {% endfor %}
                </nav>
                
                <nav class="brutal-github-nav post-action">
                    <a href="https://raw.githubusercontent.com/{{ site.ghRepo }}/main/{{ page.inputPath | replace("./", "") }}"
                        class="brutal-icon-btn" aria-label="{{ site.i18n.viewSource }}">
                        <i>{% icon "lucide:file-braces" %}</i>
                        <span class="brutal-tooltip brutal-tooltip-bottom">{{ site.i18n.viewSource }}</span>
                    </a>
                    <a href="https://github.com/{{ site.ghRepo }}/commits/main/{{ page.inputPath | replace("./", "") }}"
                        class="brutal-icon-btn" aria-label="{{ site.i18n.viewHistory }}">
                        <i>{% icon "lucide:file-clock" %}</i>
                        <span class="brutal-tooltip brutal-tooltip-bottom">{{ site.i18n.viewHistory }}</span>
                    </a>
                    <a href="https://github.com/{{ site.ghRepo }}/edit/main/{{ page.inputPath | replace("./", "") }}"
                        class="brutal-icon-btn" aria-label="{{ site.i18n.editPage }}">
                        <i>{% icon "lucide:file-pen" %}</i>
                        <span class="brutal-tooltip brutal-tooltip-bottom">{{ site.i18n.editPage }}</span>
                    </a>
                </nav>
            </div>

    {% if site.cover %}
        </div>
        
        <div class="s12 m12 l6 post-cover">
            {% if cover %}
            <img class="brutal-cover-img" src="{{ cover.img }}" alt="{{ cover.alt }}" title="{{ cover.alt }}">
            {% endif %}
        </div>
    </div>
    {% else %}
        </div>
    {% endif %}

</header>

<div class="brutal-author-block">
    {% include "components/profile.njk" %}
    <div>
        <div class="brutal-author-label">{{ site.i18n.author }}</div>
        <div class="brutal-author-name">{{ site.author }}</div>
    </div>
</div>

<div class="brutal-post-buttons-wrapper">
    {% include "components/post-buttons.njk" %}
</div>

<article class="brutal-content">
    {{ content | safe }}
</article>

<div class="overlay brutal-overlay"></div>
<dialog id="dialog-toc" class="brutal-dialog brutal-dialog-right">
    <div class="brutal-dialog-header">
        <nav class="brutal-dialog-nav">
            <h3>{{ site.i18n.tableOfContents }}</h3>
            <button class="brutal-icon-btn" data-ui="#dialog-toc" aria-label="{{ site.i18n.close }}">
                <i>{% icon "lucide:x" %}</i>
            </button>
        </nav>
    </div>
    <nav class="brutal-toc">
        {{ content | toc | safe }}
    </nav>
</dialog>
