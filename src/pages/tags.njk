---
permalink: /tags/{{ tag | slug }}/index.html
layout: layouts/default.njk
pagination:
  data: collections.tagsList
  size: 1
  alias: tag
eleventyComputed:
  title: "#{{ tag }}"
  description: "Wszystkie posty zawierające tag #{{ tag }}."
pagefind_ignore: true
---

<div class="brutal-page-wrapper">

    <header class="brutal-page-header">
        <h1 class="brutal-page-title">
            <span class="brutal-text-primary">#</span>{{ tag }}
        </h1>
    </header>

    <div class="brutal-page-grid">
        
        {% for post in collections.posts | filterByTag(tag) | reverse %}
        
        <article class="bento-card bento-card-compact">
            
            {% if site.cover and post.data.cover %}
            <img class="bento-card-img" src="{{ post.data.cover.img }}" alt="{{ post.data.cover.alt | default(post.data.title) }}">
            {% endif %}
            
            <div class="bento-tags-wrapper">
                {% set hasTags = false %}
                
                {% for postTag in post.data.tags %}
                    {% if "posts" not in postTag and "post" not in postTag %}
                    <a class="tag" href="/tags/{{ postTag | slugify }}/">#{{ postTag }}</a>
                    {% set hasTags = true %}
                    {% endif %}
                {% endfor %}
                
                {% if not hasTags %}
                    <a href="/tags/wpis/" class="tag">#Wpis</a>
                {% endif %}
            </div>
            
            <p class="bento-card-date">{{ post.date | readableDate }}</p>
            <h3 class="bento-card-title">{{ post.data.title }}</h3>
            <p class="bento-card-desc">{{ post.data.description | default('Kliknij, aby przeczytać.') }}</p>
            
            <a href="{{ post.url }}" class="read-more">Czytaj dalej &rarr;</a>
            
        </article>
        
        {% endfor %}
        
    </div>
</div>
